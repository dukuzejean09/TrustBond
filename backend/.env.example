# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/trustbond
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/trustbond

# JWT Secret (Generate a strong secret in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URLs (for CORS)
DASHBOARD_URL=http://localhost:3000
MOBILE_URL=http://localhost:8080

# File Upload
MAX_FILE_SIZE=50mb
UPLOAD_PATH=./uploads

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS Gateway (for alerts - e.g., Africa's Talking for Rwanda)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=TrustBond
