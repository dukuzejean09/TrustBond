# ── TrustBond Backend Environment Variables ──────────────────────────

# Database connection (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustbond

# JWT Secret Key – CHANGE THIS in production! Use a long random string.
SECRET_KEY=change-me-in-production

# Debug mode (set to true for development)
DEBUG=false

# CORS origins – comma-separated list of allowed dashboard URLs.
# Empty = allow all ("*") — NOT recommended for production.
# Example: CORS_ORIGINS=https://dashboard.trustbond.rw,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── Cloudinary (optional – for cloud-hosted evidence files) ──────────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ── SMTP (optional – for sending password reset emails) ──────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-specific-password
# SMTP_FROM=noreply@trustbond.rw

# Frontend URL (used in email templates for links)
FRONTEND_URL=http://localhost:5173

# Evidence add window (hours after report submission devices can still add evidence)
EVIDENCE_ADD_WINDOW_HOURS=72
