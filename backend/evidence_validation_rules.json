{
  "1": {
    "incident_name": "Theft",
    "severity": 1.2,
    "allow_no_evidence": true,
    "text_rules": {
      "min_description_chars": 25,
      "min_description_words": 5,
      "must_include_any": [
        "stole",
        "stolen",
        "thief",
        "theft",
        "robbed",
        "snatched",
        "pickpocket",
        "burglary",
        "break in",
        "took my"
      ],
      "recommended_details": [
        "what was stolen (phone/money/bag/etc.)",
        "where it happened",
        "when it happened (approx time)",
        "how it happened (snatched/forced/break-in)"
      ],
      "red_flags": [
        "just testing",
        "prank",
        "not real",
        "fake report"
      ]
    },
    "evidence_rules": {
      "allowed_media_types": ["photo", "video", "audio"],
      "recommended_media_types": ["photo", "video"],
      "min_evidence_count_for_auto_verify": 1,
      "rule": {
        "expected_objects": ["person", "cell phone", "handbag", "backpack", "rwf_note", "mobile_money"],
        "expected_actions": ["running", "grabbing", "taking", "struggling"],
        "expected_scenes": ["market", "street", "shop", "bus", "taxi"],
        "keywords": ["stole", "stolen", "thief", "theft", "robbed", "snatched"]
      }
    }
  },
